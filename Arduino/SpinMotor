#include "driver/i2c_master.h"
#include "Arduino.h"

#define I2C_PORT I2C_NUM_0
#define PCA_ADDR 0x40
#define SDA_PIN 21
#define SCL_PIN 22

i2c_master_dev_handle_t pca_handle;

void write_pca9685(uint8_t port, uint16_t off_val) {
    uint8_t data[5];
    data[0] = 0x06 + (4 * port); 
    data[1] = 0;                 
    data[2] = 0;                 
    data[3] = off_val & 0xFF;    
    data[4] = off_val >> 8;      

    i2c_master_transmit(pca_handle, data, 5, -1);
}

void init_pca9685() {
    uint8_t data[2];
    
    // 1. Sleep the chip to change frequency
    data[0] = 0x00; // MODE1 register
    data[1] = 0x10; // Sleep bit on
    i2c_master_transmit(pca_handle, data, 2, -1);
    
    // 2. Set frequency to 60Hz
    data[0] = 0xFE; // PRE_SCALE register
    data[1] = 0x65; // Math value for 60Hz
    i2c_master_transmit(pca_handle, data, 2, -1);
    
    // 3. Wake up the chip
    data[0] = 0x00; // MODE1 register
    data[1] = 0x21; // Wake up and auto-increment
    i2c_master_transmit(pca_handle, data, 2, -1);
    
    delay(5); // Wait for the chip to stabilize
}

void setup() {
    i2c_master_bus_config_t bus_config = {
        .i2c_port = I2C_PORT,
        .sda_io_num = (gpio_num_t)SDA_PIN,
        .scl_io_num = (gpio_num_t)SCL_PIN,
        .clk_source = I2C_CLK_SRC_DEFAULT,
        .glitch_ignore_cnt = 7,
        .flags = { .enable_internal_pullup = true }
    };
    
    i2c_master_bus_handle_t bus_handle;
    i2c_new_master_bus(&bus_config, &bus_handle);

    i2c_device_config_t dev_config = {
        .dev_addr_length = I2C_ADDR_BIT_LEN_7,
        .device_address = PCA_ADDR,
        .scl_speed_hz = 400000, 
    };
    
    i2c_master_bus_add_device(bus_handle, &dev_config, &pca_handle);

    // Turn on the PCA9685
    init_pca9685(); 
}

void loop() {
    write_pca9685(0, 300); 
    write_pca9685(1, 200); 
    
    delay(2000); 
    
    write_pca9685(0, 0);   
    
    delay(2000); 
}
